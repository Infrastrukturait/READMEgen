#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  readmegen [options]

Options:
  -c, --config FILE      Config file. Defaults to first existing:
                         README.yaml, README.yml, README.json
  -o, --output FILE      Output file. Default: README.md
  -t, --template FILE    Local template file.
  -u, --template-url URL Remote template URL.
  -v, --version VERSION  READMEgen git ref/tag/branch. Default: main
  --check                Do not write output. Fail if output is not up to date.
  -h, --help             Show help.

Examples:
  readmegen
  readmegen --config README.yaml
  readmegen --config README.json --output README.md
  readmegen --version v1.0.0
  readmegen --template ./README.md.template
  readmegen --check
EOF
}

CONFIG_FILE=""
OUTPUT_FILE="README.md"
TEMPLATE_FILE=""
TEMPLATE_URL=""
READMEGEN_VERSION="${READMEGEN_VERSION:-main}"
CHECK_MODE="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    -c|--config)
      CONFIG_FILE="${2:-}"
      shift 2
      ;;
    -o|--output)
      OUTPUT_FILE="${2:-}"
      shift 2
      ;;
    -t|--template)
      TEMPLATE_FILE="${2:-}"
      shift 2
      ;;
    -u|--template-url)
      TEMPLATE_URL="${2:-}"
      shift 2
      ;;
    -v|--version)
      READMEGEN_VERSION="${2:-}"
      shift 2
      ;;
    --check)
      CHECK_MODE="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

if ! command -v gomplate >/dev/null 2>&1; then
  echo "gomplate is required but was not found in PATH" >&2
  exit 4
fi

if [ -z "${CONFIG_FILE}" ]; then
  if [ -f "README.yaml" ]; then
    CONFIG_FILE="README.yaml"
  elif [ -f "README.yml" ]; then
    CONFIG_FILE="README.yml"
  elif [ -f "README.json" ]; then
    CONFIG_FILE="README.json"
  else
    echo "README config does not exist. Expected one of: README.yaml, README.yml, README.json" >&2
    exit 6
  fi
fi

if [ ! -f "${CONFIG_FILE}" ]; then
  echo "Config file does not exist: ${CONFIG_FILE}" >&2
  exit 6
fi

if [ -n "${TEMPLATE_FILE}" ] && [ -n "${TEMPLATE_URL}" ]; then
  echo "Use only one of --template or --template-url" >&2
  exit 64
fi

if [ -z "${TEMPLATE_FILE}" ] && [ -z "${TEMPLATE_URL}" ]; then
  TEMPLATE_URL="https://raw.githubusercontent.com/Infrastrukturait/READMEgen/${READMEGEN_VERSION}/README.md.template"
fi

TMP_FILE="$(mktemp)"
trap 'rm -f "${TMP_FILE}"' EXIT

if [ -n "${TEMPLATE_FILE}" ]; then
  if [ ! -f "${TEMPLATE_FILE}" ]; then
    echo "Template file does not exist: ${TEMPLATE_FILE}" >&2
    exit 7
  fi

  gomplate \
    -d "config=${CONFIG_FILE}" \
    -f "${TEMPLATE_FILE}" \
    -o "${TMP_FILE}"
else
  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is required when using a remote template" >&2
    exit 2
  fi

  curl -fsSL "${TEMPLATE_URL}" \
    | gomplate \
        -d "config=${CONFIG_FILE}" \
        > "${TMP_FILE}"
fi

if [ "${CHECK_MODE}" = "true" ]; then
  if [ -f "${OUTPUT_FILE}" ] && cmp -s "${TMP_FILE}" "${OUTPUT_FILE}"; then
    echo "${OUTPUT_FILE} is up to date"
    exit 0
  fi

  echo "${OUTPUT_FILE} is out of date. Run readmegen." >&2
  exit 1
fi

if [ -f "${OUTPUT_FILE}" ] && cmp -s "${TMP_FILE}" "${OUTPUT_FILE}"; then
  echo "${OUTPUT_FILE} is up to date"
  exit 0
fi

cp "${TMP_FILE}" "${OUTPUT_FILE}"
echo "${OUTPUT_FILE} regenerated from ${CONFIG_FILE}"
